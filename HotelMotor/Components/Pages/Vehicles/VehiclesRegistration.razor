@page "/vehicles-registration"

<h1>Registro de Vehículos</h1>

<EditForm Model="newVehicle" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="container">
        <div class="row d-flex justify-content-center">
            <div class="col-md-4">
                <div class="form-floating mb-3">
                    <select class="form-select" @bind="newVehicle.VehicleType" id="vehicle-type" required>
                        <option value="" disabled selected>Seleccionar tipo de vehículo</option>
                        <option value="Car">Carro</option>
                        <option value="Motorcycle">Moto</option>
                    </select>
                    <label for="vehicle-type">Tipo de Vehículo</label>
                </div>
            </div>
        </div>
        <div class="row d-flex justify-content-center">
            <div class="col-md-4">
                <div class="form-floating mb-3">
                    <input type="text" class="form-control" @bind="newVehicle.Brand" id="brand" placeholder="" required>
                    <label for="brand">Marca</label>
                </div>
                <div class="form-floating mb-3">
                    <input type="text" class="form-control" @bind="newVehicle.Model" id="model" placeholder="" required>
                    <label for="model">Modelo</label>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-floating mb-3">
                    <input type="number" class="form-control" @bind="newVehicle.Year" id="year" placeholder="" required>
                    <label for="year">Año</label>
                </div>
                <div class="form-floating mb-3">
                    <input type="text" class="form-control" @bind="newVehicle.PlateNumber" id="plate" placeholder="" required>
                    <label for="plate">Número de Matrícula</label>
                </div>
            </div>
            <div class="d-flex justify-content-center">
                <a class="btn btn-primary" href="/vehicles">Atrás</a>
                <button type="submit" class="btn btn-primary ms-3">Guardar Vehículo</button>
            </div>
        </div>
    </div>
</EditForm>
